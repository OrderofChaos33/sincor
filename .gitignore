# SINCOR .gitignore

# Environment variables
.env
config/.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
*.egg-info/
.pytest_cache/

# Logs
logs/
*.log

# Outputs and generated files
outputs/
*.csv
*.eml

# Database files
*.db
*.sqlite

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Backup files
*_backup.*
_pre_git_backup.*