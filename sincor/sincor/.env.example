# PayPal Configuration (REQUIRED)
PAYPAL_REST_API_ID=your_paypal_client_id
PAYPAL_REST_API_SECRET=your_paypal_client_secret
PAYPAL_ENV=sandbox
# For production use: PAYPAL_ENV=live

# Application Configuration  
APP_BASE_URL=https://getsincor.com
LOG_LEVEL=INFO

# Optional PayPal Webhook ID
PAYPAL_WEBHOOK_ID=your_webhook_id

# Railway automatically provides PORT